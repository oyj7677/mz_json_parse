{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/translate-filename.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/formatter",
      "destination": "/"
    },
    {
      "source": "/explorer",
      "destination": "/"
    },
    {
      "source": "/json-editor",
      "destination": "/"
    },
    {
      "source": "/mapping-table",
      "destination": "/"
    },
    {
      "source": "/string-resource",
      "destination": "/"
    },
    {
      "source": "/admin",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
